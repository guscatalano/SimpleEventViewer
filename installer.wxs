<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="Simple Event Viewer"
           Manufacturer="Gus Catalano"
           Version="$(var.AppVersion)"
           UpgradeCode="b16c5a76-3f47-4f76-a932-bb6c2e6b67ee"
           Scope="perMachine">

    <MediaTemplate EmbedCab="yes" />
    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="Simple Event Viewer" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppShortcutFolder" Name="Simple Event Viewer" />
    </StandardDirectory>

    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <Files Include="publish\**" />
    </ComponentGroup>

    <Component Id="AppShortcut" Directory="AppShortcutFolder" Guid="b3c9c8f2-1e5b-4d33-9a90-7e6f2a82f4d1">
      <Shortcut Id="StartMenuShortcut"
                Name="Simple Event Viewer"
                Description="Windows Event Log viewer"
                Target="[INSTALLFOLDER]SimpleEventViewer.WinUI.exe"
                WorkingDirectory="INSTALLFOLDER" />
      <RemoveFolder Id="RemoveAppShortcutFolder" On="uninstall" />
      <RegistryValue Root="HKCU" Key="Software\GusCatalano\SimpleEventViewer"
                     Name="installed" Type="integer" Value="1" KeyPath="yes" />
    </Component>

    <Feature Id="MainApp" Title="Simple Event Viewer" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
      <ComponentRef Id="AppShortcut" />
    </Feature>
  </Package>
</Wix>
