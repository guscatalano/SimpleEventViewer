<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="SimpleEventViewer_WinUI.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:SimpleEventViewer_WinUI"
    xmlns:models="using:SimpleEventViewer_WinUI.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="12" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Top: Toolbar -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <CommandBar Grid.Column="0" DefaultLabelPosition="Right" HorizontalAlignment="Left" Background="Transparent">
                <AppBarButton Icon="Refresh" Label="Refresh" Click="RefreshButton_Click" />
                <AppBarSeparator />
                <AppBarButton Icon="OpenFile" Label="Load EVTX" Click="LoadEvtxFile_Click" />
                <AppBarButton Icon="OpenFile" Label="Load XML" Click="LoadXmlFile_Click" />
                <AppBarButton Icon="OpenFile" Label="Load ETL" Click="LoadEtlFile_Click" />
            </CommandBar>
            <Button Grid.Column="1" Click="SettingsButton_Click" Padding="8" VerticalAlignment="Center" Margin="0,0,8,0"
                    ToolTipService.ToolTip="Settings">
                <FontIcon Glyph="&#xE713;" FontSize="16" />
            </Button>
        </Grid>

        <!-- Main content -->
        <Grid Grid.Row="1" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left: Filters -->
            <Border Grid.Column="0" Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8">
                <ScrollViewer>
                    <StackPanel Padding="16" Spacing="16">
                        <TextBlock Text="Filters" FontSize="18" FontWeight="SemiBold" />

                        <StackPanel Spacing="6">
                            <TextBlock Text="Event Source" FontWeight="SemiBold" FontSize="13" />
                            <ComboBox ItemsSource="{x:Bind ViewModel.SourceCategories, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.SelectedSource, Mode=TwoWay}"
                                      DisplayMemberPath="Display"
                                      HorizontalAlignment="Stretch" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Event Level" FontWeight="SemiBold" FontSize="13" />
                            <ComboBox ItemsSource="{x:Bind ViewModel.AvailableTypes, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.SelectedType, Mode=TwoWay}"
                                      DisplayMemberPath="Name"
                                      HorizontalAlignment="Stretch" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Time Range" FontWeight="SemiBold" FontSize="13" />
                            <DatePicker x:Name="StartDatePicker"
                                        Header="From"
                                        Date="{x:Bind ViewModel.StartTime, Mode=TwoWay, Converter={StaticResource DateOffsetConverter}}"
                                        HorizontalAlignment="Stretch" />
                            <DatePicker x:Name="EndDatePicker"
                                        Header="To"
                                        Date="{x:Bind ViewModel.EndTime, Mode=TwoWay, Converter={StaticResource DateOffsetConverter}}"
                                        HorizontalAlignment="Stretch" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Search" FontWeight="SemiBold" FontSize="13" />
                            <TextBox PlaceholderText="Search messages..."
                                     Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <Button Content="Clear All Filters" Click="ClearFilters_Click"
                                HorizontalAlignment="Stretch" />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Right: Events + Details -->
            <Grid Grid.Column="1" RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Events list -->
                <Border Grid.Row="0" Background="{ThemeResource LayerFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Padding="12,8" Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Time" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="Level" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="2" Text="ID" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="3" Text="Source" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="4" Text="Message" FontWeight="SemiBold" />
                        </Grid>

                        <ListView Grid.Row="1"
                                  ItemsSource="{x:Bind ViewModel.FilteredEvents, Mode=OneWay}"
                                  SelectedItem="{x:Bind ViewModel.SelectedEvent, Mode=TwoWay}"
                                  SelectionMode="Single">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="12,4" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:EventLogEntry">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="60" />
                                            <ColumnDefinition Width="180" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{x:Bind TimeCreatedDisplay}" />
                                        <TextBlock Grid.Column="1" Text="{x:Bind LevelName}" />
                                        <TextBlock Grid.Column="2" Text="{x:Bind Id}" />
                                        <TextBlock Grid.Column="3" Text="{x:Bind ProviderName}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="4" Text="{x:Bind Message}" TextTrimming="CharacterEllipsis" MaxLines="1" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>

                <!-- Event details -->
                <Border Grid.Row="1" Background="{ThemeResource LayerFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8">
                    <ScrollViewer>
                        <StackPanel Padding="16" Spacing="8">
                            <TextBlock Text="Event Details" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <Grid Visibility="{x:Bind ViewModel.SelectedEvent, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                                <StackPanel Spacing="6">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Event ID:" FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.SelectedEvent.Id, Mode=OneWay}" />
                                    </Grid>
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Level:" FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.SelectedEvent.LevelName, Mode=OneWay}" />
                                    </Grid>
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Time Created:" FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.SelectedEvent.TimeCreatedDisplay, Mode=OneWay}" />
                                    </Grid>
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Provider:" FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.SelectedEvent.ProviderName, Mode=OneWay}" TextWrapping="Wrap" />
                                    </Grid>
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Task:" FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.SelectedEvent.TaskName, Mode=OneWay}" />
                                    </Grid>
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Keywords:" FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.SelectedEvent.Keywords, Mode=OneWay}" />
                                    </Grid>
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="User:" FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.SelectedEvent.Username, Mode=OneWay}" />
                                    </Grid>
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Process / Thread:" FontWeight="SemiBold" />
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{x:Bind ViewModel.SelectedEvent.ProcessId, Mode=OneWay}" />
                                            <TextBlock Text="/" />
                                            <TextBlock Text="{x:Bind ViewModel.SelectedEvent.ThreadId, Mode=OneWay}" />
                                        </StackPanel>
                                    </Grid>
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Computer:" FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.SelectedEvent.Computer, Mode=OneWay}" />
                                    </Grid>
                                    <StackPanel Spacing="6" Margin="0,4,0,0">
                                        <TextBlock Text="Message:" FontWeight="SemiBold" />
                                        <TextBlock Text="{x:Bind ViewModel.SelectedEvent.Message, Mode=OneWay}" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <Expander Header="XML View" HorizontalAlignment="Stretch" Margin="0,8,0,0">
                                        <TextBox Text="{x:Bind ViewModel.SelectedEvent.Xml, Mode=OneWay}"
                                                 IsReadOnly="True"
                                                 TextWrapping="Wrap"
                                                 AcceptsReturn="True"
                                                 FontFamily="Consolas"
                                                 Height="200" />
                                    </Expander>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>

        <!-- Bottom: Status bar -->
        <Border Grid.Row="2" Padding="12,6" Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="4">
            <StackPanel Orientation="Horizontal" Spacing="16">
                <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" />
                <TextBlock Text="•" Opacity="0.5" />
                <TextBlock>
                    <Run Text="Showing" />
                    <Run Text="{x:Bind ViewModel.FilteredEvents.Count, Mode=OneWay}" />
                    <Run Text="events" />
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Page>
