<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="SimpleEventViewer.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:SimpleEventViewer"
    xmlns:models="using:SimpleEventViewer.Models"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:tkcontrols="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Required">

    <Page.KeyboardAccelerators>
        <KeyboardAccelerator Modifiers="Control" Key="F" Invoked="FindAccelerator_Invoked" />
    </Page.KeyboardAccelerators>

    <Grid Padding="12" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Top: Toolbar -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <CommandBar Grid.Column="0" DefaultLabelPosition="Right" HorizontalAlignment="Left" Background="Transparent">
                <AppBarButton Icon="OpenFile" Label="Open"
                              ToolTipService.ToolTip="Choose a data source to load">
                    <AppBarButton.Flyout>
                        <MenuFlyout>
                            <MenuFlyoutItem Text="Live Windows event log" Click="LoadLocalEventLog_Click">
                                <MenuFlyoutItem.Icon>
                                    <SymbolIcon Symbol="Admin" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutSeparator />
                            <MenuFlyoutItem Text="EVTX file…" Click="LoadEvtxFile_Click">
                                <MenuFlyoutItem.Icon>
                                    <SymbolIcon Symbol="OpenFile" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem x:Name="LoadXmlMenuItem"
                                            Text="XML file… (experimental)"
                                            Click="LoadXmlFile_Click"
                                            Visibility="Collapsed">
                                <MenuFlyoutItem.Icon>
                                    <SymbolIcon Symbol="OpenFile" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem x:Name="LoadEtlMenuItem"
                                            Text="ETL file… (experimental)"
                                            Click="LoadEtlFile_Click"
                                            Visibility="Collapsed">
                                <MenuFlyoutItem.Icon>
                                    <SymbolIcon Symbol="OpenFile" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </AppBarButton.Flyout>
                </AppBarButton>
                <AppBarButton Icon="Refresh" Label="{x:Bind ViewModel.RefreshButtonLabel, Mode=OneWay}"
                              Click="RefreshButton_Click"
                              ToolTipService.ToolTip="Re-read the current source (live or file) and re-apply the active filters" />
            </CommandBar>
            <!-- Ctrl+F find bar — vertically aligned with the toolbar so it
                 doesn't overlap the events grid. Right-edge of the same row
                 as the Open / Refresh / Settings controls. -->
            <Border x:Name="FindBar" Grid.Column="0" Visibility="Collapsed"
                    HorizontalAlignment="Right" VerticalAlignment="Center"
                    Margin="0,0,8,0" Padding="8,4"
                    Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                    BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="6">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE721;" FontSize="13" VerticalAlignment="Center" Opacity="0.7" />
                    <TextBox x:Name="FindBox" Width="260"
                             PlaceholderText="Find in message, source, level…"
                             Text="{x:Bind ViewModel.QuickFindText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             KeyDown="FindBox_KeyDown" />
                    <Button Click="CloseFindBar_Click" Padding="6"
                            Background="Transparent" BorderThickness="0"
                            ToolTipService.ToolTip="Close (Esc)">
                        <FontIcon Glyph="&#xE711;" FontSize="11" />
                    </Button>
                </StackPanel>
            </Border>
            <Button Grid.Column="1" x:Name="SettingsButton"
                    Click="SettingsButton_Click" Padding="8" VerticalAlignment="Center" Margin="0,0,8,0"
                    AutomationProperties.Name="Settings"
                    ToolTipService.ToolTip="Settings">
                <FontIcon Glyph="&#xE713;" FontSize="16" />
            </Button>
        </Grid>

        <!-- Main content -->
        <Grid Grid.Row="1" ColumnSpacing="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="FilterColumn" Width="300" />
                <ColumnDefinition x:Name="SplitterColumn" Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Collapsed filter button (overlays when filter is collapsed) -->
            <Border x:Name="CollapsedFilterButton" Grid.Column="0" Visibility="Collapsed"
                    HorizontalAlignment="Left" VerticalAlignment="Top">
                <Button Click="ExpandFilters_Click" Padding="8" Margin="0,4,0,0"
                        ToolTipService.ToolTip="Show filters">
                    <FontIcon Glyph="&#xE71C;" FontSize="14" />
                </Button>
            </Border>

            <!-- Left: Filters (visible when not collapsed) -->
            <Border x:Name="FilterPanel" Grid.Column="0" Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Margin="0,0,4,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Padding="16,12,8,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Filters" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Click="CollapseFilters_Click" Padding="6"
                                ToolTipService.ToolTip="Collapse filters"
                                Background="Transparent" BorderThickness="0">
                            <FontIcon Glyph="&#xE76B;" FontSize="12" />
                        </Button>
                    </Grid>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" VerticalScrollMode="Auto">
                        <StackPanel Padding="16,4,16,16" Spacing="16">
                            <StackPanel x:Name="SourceFilterSection" Spacing="6"
                                        Visibility="{x:Bind ViewModel.SourceSectionVisibility, Mode=OneWay}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Border Width="3" Background="{ThemeResource AccentFillColorDefaultBrush}" CornerRadius="2"
                                            Visibility="{x:Bind ViewModel.IsSourceFilterActive, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <TextBlock Text="Event Source" FontWeight="SemiBold" FontSize="13" />
                                </StackPanel>
                                <ComboBox ItemsSource="{x:Bind ViewModel.SourceCategories, Mode=OneWay}"
                                          SelectedItem="{x:Bind ViewModel.SelectedSource, Mode=TwoWay}"
                                          DisplayMemberPath="Display"
                                          HorizontalAlignment="Stretch"
                                          Visibility="{x:Bind ViewModel.SourceComboBoxVisibility, Mode=OneWay}" />
                                <DropDownButton Content="{x:Bind ViewModel.SourceFilterSummary, Mode=OneWay}"
                                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                                Visibility="{x:Bind ViewModel.SourceDropDownVisibility, Mode=OneWay}">
                                    <DropDownButton.Flyout>
                                        <Flyout Placement="Bottom">
                                            <ListView ItemsSource="{x:Bind ViewModel.SourceCategories, Mode=OneWay}"
                                                      SelectionMode="None" IsItemClickEnabled="False"
                                                      MinWidth="280" MaxHeight="400">
                                                <ListView.ItemContainerStyle>
                                                    <Style TargetType="ListViewItem">
                                                        <Setter Property="Visibility" Value="{Binding IsListRow, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                    </Style>
                                                </ListView.ItemContainerStyle>
                                                <ListView.ItemTemplate>
                                                    <DataTemplate x:DataType="models:SourceCategory">
                                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                  Content="{x:Bind Display}"
                                                                  MinWidth="240" />
                                                    </DataTemplate>
                                                </ListView.ItemTemplate>
                                            </ListView>
                                        </Flyout>
                                    </DropDownButton.Flyout>
                                </DropDownButton>
                            </StackPanel>

                            <StackPanel x:Name="TimeFilterSection" Spacing="6"
                                        Visibility="{x:Bind ViewModel.TimeSectionVisibility, Mode=OneWay}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Border Width="3" Background="{ThemeResource AccentFillColorDefaultBrush}" CornerRadius="2"
                                            Visibility="{x:Bind ViewModel.IsTimeFilterActive, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <TextBlock Text="Time Range" FontWeight="SemiBold" FontSize="13" />
                                </StackPanel>
                                <ComboBox ItemsSource="{x:Bind ViewModel.LoadWindows, Mode=OneWay}"
                                          SelectedItem="{x:Bind ViewModel.SelectedLoadWindow, Mode=TwoWay}"
                                          DisplayMemberPath="Name"
                                          HorizontalAlignment="Stretch" />
                                <StackPanel Spacing="6" Margin="0,4,0,0"
                                            Visibility="{x:Bind ViewModel.IsCustomRange, Mode=OneWay}">
                                    <TextBlock Text="From" Opacity="0.7" FontSize="11" />
                                    <CalendarDatePicker x:Name="StartDatePicker"
                                                        PlaceholderText="Date"
                                                        Date="{x:Bind ViewModel.StartTime, Mode=TwoWay, Converter={StaticResource DateOffsetConverter}}"
                                                        HorizontalAlignment="Stretch" />
                                    <TimePicker x:Name="StartTimePicker"
                                                ClockIdentifier="24HourClock"
                                                SelectedTime="{x:Bind ViewModel.StartTimeOfDay, Mode=TwoWay, Converter={StaticResource TimeSpanConverter}}"
                                                HorizontalAlignment="Stretch" />
                                    <TextBlock Text="To" Opacity="0.7" FontSize="11" Margin="0,4,0,0" />
                                    <CalendarDatePicker x:Name="EndDatePicker"
                                                        PlaceholderText="Date"
                                                        Date="{x:Bind ViewModel.EndTime, Mode=TwoWay, Converter={StaticResource DateOffsetConverter}}"
                                                        HorizontalAlignment="Stretch" />
                                    <TimePicker x:Name="EndTimePicker"
                                                ClockIdentifier="24HourClock"
                                                SelectedTime="{x:Bind ViewModel.EndTimeOfDay, Mode=TwoWay, Converter={StaticResource TimeSpanConverter}}"
                                                HorizontalAlignment="Stretch" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel x:Name="LevelFilterSection" Spacing="6"
                                        Visibility="{x:Bind ViewModel.LevelSectionVisibility, Mode=OneWay}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Border Width="3" Background="{ThemeResource AccentFillColorDefaultBrush}" CornerRadius="2"
                                            Visibility="{x:Bind ViewModel.IsLevelFilterActive, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <TextBlock Text="Event Level" FontWeight="SemiBold" FontSize="13" />
                                </StackPanel>
                                <ComboBox ItemsSource="{x:Bind ViewModel.AvailableTypes, Mode=OneWay}"
                                          SelectedItem="{x:Bind ViewModel.SelectedType, Mode=TwoWay}"
                                          DisplayMemberPath="Name"
                                          HorizontalAlignment="Stretch"
                                          Visibility="{x:Bind ViewModel.LevelComboBoxVisibility, Mode=OneWay}" />
                                <DropDownButton Content="{x:Bind ViewModel.LevelFilterSummary, Mode=OneWay}"
                                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                                Visibility="{x:Bind ViewModel.LevelDropDownVisibility, Mode=OneWay}">
                                    <DropDownButton.Flyout>
                                        <Flyout Placement="Bottom">
                                            <ListView ItemsSource="{x:Bind ViewModel.AvailableTypes, Mode=OneWay}"
                                                      SelectionMode="None" IsItemClickEnabled="False"
                                                      MinWidth="220" MaxHeight="400">
                                                <ListView.ItemContainerStyle>
                                                    <Style TargetType="ListViewItem">
                                                        <Setter Property="Visibility" Value="{Binding IsListRow, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                    </Style>
                                                </ListView.ItemContainerStyle>
                                                <ListView.ItemTemplate>
                                                    <DataTemplate>
                                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                  Content="{Binding Name}"
                                                                  MinWidth="180" />
                                                    </DataTemplate>
                                                </ListView.ItemTemplate>
                                            </ListView>
                                        </Flyout>
                                    </DropDownButton.Flyout>
                                </DropDownButton>
                            </StackPanel>

                            <StackPanel x:Name="IdFilterSection" Spacing="6"
                                        Visibility="{x:Bind ViewModel.IdSectionVisibility, Mode=OneWay}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Border Width="3" Background="{ThemeResource AccentFillColorDefaultBrush}" CornerRadius="2"
                                            Visibility="{x:Bind ViewModel.IsIdFilterActive, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <TextBlock Text="Event ID" FontWeight="SemiBold" FontSize="13" />
                                </StackPanel>
                                <ComboBox ItemsSource="{x:Bind ViewModel.IdCategories, Mode=OneWay}"
                                          SelectedItem="{x:Bind ViewModel.SelectedId, Mode=TwoWay}"
                                          DisplayMemberPath="Display"
                                          HorizontalAlignment="Stretch"
                                          Visibility="{x:Bind ViewModel.IdComboBoxVisibility, Mode=OneWay}" />
                                <DropDownButton Content="{x:Bind ViewModel.IdFilterSummary, Mode=OneWay}"
                                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                                Visibility="{x:Bind ViewModel.IdDropDownVisibility, Mode=OneWay}">
                                    <DropDownButton.Flyout>
                                        <Flyout Placement="Bottom">
                                            <ListView ItemsSource="{x:Bind ViewModel.IdCategories, Mode=OneWay}"
                                                      SelectionMode="None" IsItemClickEnabled="False"
                                                      MinWidth="220" MaxHeight="400">
                                                <ListView.ItemContainerStyle>
                                                    <Style TargetType="ListViewItem">
                                                        <Setter Property="Visibility" Value="{Binding IsListRow, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                    </Style>
                                                </ListView.ItemContainerStyle>
                                                <ListView.ItemTemplate>
                                                    <DataTemplate x:DataType="models:SourceCategory">
                                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                  Content="{x:Bind Display}"
                                                                  MinWidth="180" />
                                                    </DataTemplate>
                                                </ListView.ItemTemplate>
                                            </ListView>
                                        </Flyout>
                                    </DropDownButton.Flyout>
                                </DropDownButton>
                            </StackPanel>

                            <StackPanel x:Name="MessageFilterSection" Spacing="6"
                                        Visibility="{x:Bind ViewModel.MessageSectionVisibility, Mode=OneWay}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Border Width="3" Background="{ThemeResource AccentFillColorDefaultBrush}" CornerRadius="2"
                                            Visibility="{x:Bind ViewModel.IsMessageFilterActive, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <TextBlock Text="Message" FontWeight="SemiBold" FontSize="13" />
                                </StackPanel>
                                <TextBox PlaceholderText="Search messages..."
                                         Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel x:Name="UserFilterSection" Spacing="6"
                                        Visibility="{x:Bind ViewModel.UserSectionVisibility, Mode=OneWay}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Border Width="3" Background="{ThemeResource AccentFillColorDefaultBrush}" CornerRadius="2"
                                            Visibility="{x:Bind ViewModel.IsUserFilterActive, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <TextBlock Text="User" FontWeight="SemiBold" FontSize="13" />
                                </StackPanel>
                                <ComboBox ItemsSource="{x:Bind ViewModel.UserCategories, Mode=OneWay}"
                                          SelectedItem="{x:Bind ViewModel.SelectedUser, Mode=TwoWay}"
                                          DisplayMemberPath="Display"
                                          HorizontalAlignment="Stretch"
                                          Visibility="{x:Bind ViewModel.UserComboBoxVisibility, Mode=OneWay}" />
                                <DropDownButton Content="{x:Bind ViewModel.UserFilterSummary, Mode=OneWay}"
                                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                                Visibility="{x:Bind ViewModel.UserDropDownVisibility, Mode=OneWay}">
                                    <DropDownButton.Flyout>
                                        <Flyout Placement="Bottom">
                                            <ListView ItemsSource="{x:Bind ViewModel.UserCategories, Mode=OneWay}"
                                                      SelectionMode="None" IsItemClickEnabled="False"
                                                      MinWidth="260" MaxHeight="400">
                                                <ListView.ItemContainerStyle>
                                                    <Style TargetType="ListViewItem">
                                                        <Setter Property="Visibility" Value="{Binding IsListRow, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                    </Style>
                                                </ListView.ItemContainerStyle>
                                                <ListView.ItemTemplate>
                                                    <DataTemplate x:DataType="models:SourceCategory">
                                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                  Content="{x:Bind Display}"
                                                                  MinWidth="220" />
                                                    </DataTemplate>
                                                </ListView.ItemTemplate>
                                            </ListView>
                                        </Flyout>
                                    </DropDownButton.Flyout>
                                </DropDownButton>
                            </StackPanel>

                            <StackPanel x:Name="ProcessFilterSection" Spacing="6"
                                        Visibility="{x:Bind ViewModel.ProcessSectionVisibility, Mode=OneWay}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Border Width="3" Background="{ThemeResource AccentFillColorDefaultBrush}" CornerRadius="2"
                                            Visibility="{x:Bind ViewModel.IsProcessFilterActive, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <TextBlock Text="Process" FontWeight="SemiBold" FontSize="13" />
                                </StackPanel>
                                <ComboBox ItemsSource="{x:Bind ViewModel.ProcessCategories, Mode=OneWay}"
                                          SelectedItem="{x:Bind ViewModel.SelectedProcess, Mode=TwoWay}"
                                          DisplayMemberPath="Display"
                                          HorizontalAlignment="Stretch"
                                          Visibility="{x:Bind ViewModel.ProcessComboBoxVisibility, Mode=OneWay}" />
                                <DropDownButton Content="{x:Bind ViewModel.ProcessFilterSummary, Mode=OneWay}"
                                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                                Visibility="{x:Bind ViewModel.ProcessDropDownVisibility, Mode=OneWay}">
                                    <DropDownButton.Flyout>
                                        <Flyout Placement="Bottom">
                                            <ListView ItemsSource="{x:Bind ViewModel.ProcessCategories, Mode=OneWay}"
                                                      SelectionMode="None" IsItemClickEnabled="False"
                                                      MinWidth="220" MaxHeight="400">
                                                <ListView.ItemContainerStyle>
                                                    <Style TargetType="ListViewItem">
                                                        <Setter Property="Visibility" Value="{Binding IsListRow, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                    </Style>
                                                </ListView.ItemContainerStyle>
                                                <ListView.ItemTemplate>
                                                    <DataTemplate x:DataType="models:SourceCategory">
                                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                  Content="{x:Bind Display}"
                                                                  MinWidth="180" />
                                                    </DataTemplate>
                                                </ListView.ItemTemplate>
                                            </ListView>
                                        </Flyout>
                                    </DropDownButton.Flyout>
                                </DropDownButton>
                            </StackPanel>

                            <StackPanel x:Name="ComputerFilterSection" Spacing="6"
                                        Visibility="{x:Bind ViewModel.ComputerSectionVisibility, Mode=OneWay}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Border Width="3" Background="{ThemeResource AccentFillColorDefaultBrush}" CornerRadius="2"
                                            Visibility="{x:Bind ViewModel.IsComputerFilterActive, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <TextBlock Text="Computer" FontWeight="SemiBold" FontSize="13" />
                                </StackPanel>
                                <ComboBox ItemsSource="{x:Bind ViewModel.ComputerCategories, Mode=OneWay}"
                                          SelectedItem="{x:Bind ViewModel.SelectedComputer, Mode=TwoWay}"
                                          DisplayMemberPath="Display"
                                          HorizontalAlignment="Stretch"
                                          Visibility="{x:Bind ViewModel.ComputerComboBoxVisibility, Mode=OneWay}" />
                                <DropDownButton Content="{x:Bind ViewModel.ComputerFilterSummary, Mode=OneWay}"
                                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                                Visibility="{x:Bind ViewModel.ComputerDropDownVisibility, Mode=OneWay}">
                                    <DropDownButton.Flyout>
                                        <Flyout Placement="Bottom">
                                            <ListView ItemsSource="{x:Bind ViewModel.ComputerCategories, Mode=OneWay}"
                                                      SelectionMode="None" IsItemClickEnabled="False"
                                                      MinWidth="260" MaxHeight="400">
                                                <ListView.ItemContainerStyle>
                                                    <Style TargetType="ListViewItem">
                                                        <Setter Property="Visibility" Value="{Binding IsListRow, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                    </Style>
                                                </ListView.ItemContainerStyle>
                                                <ListView.ItemTemplate>
                                                    <DataTemplate x:DataType="models:SourceCategory">
                                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                  Content="{x:Bind Display}"
                                                                  MinWidth="220" />
                                                    </DataTemplate>
                                                </ListView.ItemTemplate>
                                            </ListView>
                                        </Flyout>
                                    </DropDownButton.Flyout>
                                </DropDownButton>
                            </StackPanel>

                            <StackPanel x:Name="ChannelFilterSection" Spacing="6"
                                        Visibility="{x:Bind ViewModel.ChannelSectionVisibility, Mode=OneWay}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Border Width="3" Background="{ThemeResource AccentFillColorDefaultBrush}" CornerRadius="2"
                                            Visibility="{x:Bind ViewModel.IsChannelFilterActive, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <TextBlock Text="Channel" FontWeight="SemiBold" FontSize="13" />
                                </StackPanel>
                                <ComboBox ItemsSource="{x:Bind ViewModel.ChannelCategories, Mode=OneWay}"
                                          SelectedItem="{x:Bind ViewModel.SelectedChannel, Mode=TwoWay}"
                                          DisplayMemberPath="Display"
                                          HorizontalAlignment="Stretch"
                                          Visibility="{x:Bind ViewModel.ChannelComboBoxVisibility, Mode=OneWay}" />
                                <DropDownButton Content="{x:Bind ViewModel.ChannelFilterSummary, Mode=OneWay}"
                                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                                Visibility="{x:Bind ViewModel.ChannelDropDownVisibility, Mode=OneWay}">
                                    <DropDownButton.Flyout>
                                        <Flyout Placement="Bottom">
                                            <ListView ItemsSource="{x:Bind ViewModel.ChannelCategories, Mode=OneWay}"
                                                      SelectionMode="None" IsItemClickEnabled="False"
                                                      MinWidth="260" MaxHeight="400">
                                                <ListView.ItemContainerStyle>
                                                    <Style TargetType="ListViewItem">
                                                        <Setter Property="Visibility" Value="{Binding IsListRow, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                    </Style>
                                                </ListView.ItemContainerStyle>
                                                <ListView.ItemTemplate>
                                                    <DataTemplate x:DataType="models:SourceCategory">
                                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                  Content="{x:Bind Display}"
                                                                  MinWidth="220" />
                                                    </DataTemplate>
                                                </ListView.ItemTemplate>
                                            </ListView>
                                        </Flyout>
                                    </DropDownButton.Flyout>
                                </DropDownButton>
                            </StackPanel>

                            <Grid ColumnSpacing="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Click="SaveFilters_Click"
                                        HorizontalAlignment="Stretch"
                                        ToolTipService.ToolTip="Save the current filters as a JSON file">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <FontIcon Glyph="&#xE74E;" FontSize="12" />
                                        <TextBlock Text="Save filters" FontSize="12" />
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="1" Click="LoadFilters_Click"
                                        HorizontalAlignment="Stretch"
                                        ToolTipService.ToolTip="Load filters from a JSON file">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <FontIcon Glyph="&#xE8E5;" FontSize="12" />
                                        <TextBlock Text="Load filters" FontSize="12" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                            <Button Content="Clear All Filters" Click="ClearFilters_Click"
                                    HorizontalAlignment="Stretch" />
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Grid splitter for resizing -->
            <controls:GridSplitter x:Name="FilterSplitter" Grid.Column="1"
                                   Width="6"
                                   HorizontalAlignment="Center" VerticalAlignment="Stretch"
                                   ResizeBehavior="PreviousAndNext"
                                   ResizeDirection="Columns" />

            <!-- Right: Events + Details (column 2) -->
            <Grid Grid.Column="2" RowSpacing="0" Margin="4,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition x:Name="DetailsSplitterRow" Height="Auto" />
                    <RowDefinition x:Name="DetailsRow" Height="280" />
                </Grid.RowDefinitions>

                <!-- Events list -->
                <Border Grid.Row="0" Background="{ThemeResource LayerFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Padding="8,4" Spacing="4">
                            <Button Click="ExportButton_Click" Padding="6" Background="Transparent" BorderThickness="0"
                                    ToolTipService.ToolTip="Export current view to CSV / JSON / XML">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <FontIcon Glyph="&#xEDE1;" FontSize="13" />
                                    <TextBlock Text="Export" FontSize="12" />
                                </StackPanel>
                            </Button>
                            <Button Click="ColumnsButton_Click" Padding="6" Background="Transparent" BorderThickness="0"
                                    ToolTipService.ToolTip="Show/hide columns">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <FontIcon Glyph="&#xE71D;" FontSize="13" />
                                    <TextBlock Text="Columns" FontSize="12" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                        <tkcontrols:DataGrid Grid.Row="1" x:Name="EventsDataGrid"
                                          ItemsSource="{x:Bind ViewModel.FilteredEvents, Mode=OneWay}"
                                          SelectedItem="{x:Bind ViewModel.SelectedEvent, Mode=TwoWay}"
                                          AutoGenerateColumns="False"
                                          CanUserResizeColumns="True"
                                          CanUserSortColumns="True"
                                          CanUserReorderColumns="True"
                                          GridLinesVisibility="Horizontal"
                                          HeadersVisibility="Column"
                                          SelectionMode="Extended"
                                          IsReadOnly="True"
                                          RightTapped="EventsDataGrid_RightTapped"
                                          Sorting="EventsDataGrid_Sorting"
                                          LoadingRow="EventsDataGrid_LoadingRow">
                            <tkcontrols:DataGrid.RowStyle>
                                <Style TargetType="tkcontrols:DataGridRow">
                                    <!-- Row tint is data-driven via Level + the row brush converter
                                         (which reads the current Color Scheme + Row Color Mode).
                                         INPC on Level forces re-evaluation when the scheme changes. -->
                                    <Setter Property="Background"
                                            Value="{Binding Level, Converter={StaticResource LevelToRowBrushConverter}}" />
                                </Style>
                            </tkcontrols:DataGrid.RowStyle>
                        <tkcontrols:DataGrid.Columns>
                            <tkcontrols:DataGridTextColumn Header="Time" Tag="Time" Binding="{Binding TimeCreatedDisplay}" Width="160" />
                            <tkcontrols:DataGridTemplateColumn Header="Level" Tag="Level" Width="100">
                                <tkcontrols:DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate x:DataType="models:EventLogEntry">
                                        <Border Background="{x:Bind Level, Mode=OneWay, Converter={StaticResource LevelToBrushConverter}}"
                                                CornerRadius="3"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center"
                                                Padding="8,2"
                                                Margin="6,0">
                                            <TextBlock Text="{x:Bind LevelName, Mode=OneWay}"
                                                       Foreground="{x:Bind Level, Mode=OneWay, Converter={StaticResource LevelToTextBrushConverter}}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold" />
                                        </Border>
                                    </DataTemplate>
                                </tkcontrols:DataGridTemplateColumn.CellTemplate>
                            </tkcontrols:DataGridTemplateColumn>
                            <tkcontrols:DataGridTextColumn Header="ID" Tag="Id" Binding="{Binding Id}" Width="60" />
                            <tkcontrols:DataGridTextColumn Header="Source" Tag="Source" Binding="{Binding ProviderName}" Width="180" />
                            <tkcontrols:DataGridTextColumn Header="Channel" Tag="Channel" Binding="{Binding Channel}" Width="150" Visibility="Collapsed" />
                            <tkcontrols:DataGridTextColumn Header="User" Tag="User" Binding="{Binding Username}" Width="120" />
                            <tkcontrols:DataGridTemplateColumn Header="Message" Tag="Message" Width="*">
                                <tkcontrols:DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Message}"
                                                   x:Name="MessageText"
                                                   TextWrapping="Wrap"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxLines="1"
                                                   VerticalAlignment="Center"
                                                   Loaded="MessageText_Loaded" />
                                    </DataTemplate>
                                </tkcontrols:DataGridTemplateColumn.CellTemplate>
                            </tkcontrols:DataGridTemplateColumn>
                        </tkcontrols:DataGrid.Columns>
                    </tkcontrols:DataGrid>
                    </Grid>
                </Border>

                <!-- Vertical grid splitter between events and details -->
                <controls:GridSplitter x:Name="DetailsSplitter" Grid.Row="1" Height="6"
                                       HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                       ResizeBehavior="PreviousAndNext"
                                       ResizeDirection="Rows" />

                <!-- Event details -->
                <Border x:Name="DetailsPanel" Grid.Row="2" Background="{ThemeResource LayerFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Margin="0,2,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Padding="16,12,8,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Event Details" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <Button Grid.Column="1" Click="CopyAllDetails_Click" Padding="6" Margin="0,0,4,0"
                                    ToolTipService.ToolTip="Copy all details"
                                    Background="Transparent" BorderThickness="0">
                                <FontIcon Glyph="&#xE8C8;" FontSize="14" />
                            </Button>
                            <Button Grid.Column="2" Click="CollapseDetails_Click" Padding="6"
                                    ToolTipService.ToolTip="Collapse details"
                                    Background="Transparent" BorderThickness="0">
                                <FontIcon Glyph="&#xE74B;" FontSize="12" />
                            </Button>
                        </Grid>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel Padding="16,4,16,16" Spacing="8">
                            <Grid Visibility="{x:Bind ViewModel.SelectedEvent, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                                <StackPanel Spacing="6">
                                    <Grid ColumnSpacing="6" Visibility="{x:Bind ViewModel.DetailIdVisibility, Mode=OneWay}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="1" Text="Event ID:" FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="2" IsTextSelectionEnabled="True" Text="{x:Bind ViewModel.SelectedEvent.Id, Mode=OneWay}" />
                                        <Button Grid.Column="0" Click="CopyDetailField_Click" Padding="4" Background="Transparent" BorderThickness="0"
                                                ToolTipService.ToolTip="Copy"
                                                Tag="{x:Bind ViewModel.SelectedEvent.Id, Mode=OneWay}">
                                            <FontIcon Glyph="&#xE8C8;" FontSize="11" />
                                        </Button>
                                    </Grid>
                                    <Grid ColumnSpacing="6" Visibility="{x:Bind ViewModel.DetailLevelVisibility, Mode=OneWay}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="1" Text="Level:" FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="2" IsTextSelectionEnabled="True" Text="{x:Bind ViewModel.SelectedEvent.LevelName, Mode=OneWay}" />
                                        <Button Grid.Column="0" Click="CopyDetailField_Click" Padding="4" Background="Transparent" BorderThickness="0"
                                                ToolTipService.ToolTip="Copy"
                                                Tag="{x:Bind ViewModel.SelectedEvent.LevelName, Mode=OneWay}">
                                            <FontIcon Glyph="&#xE8C8;" FontSize="11" />
                                        </Button>
                                    </Grid>
                                    <Grid ColumnSpacing="6" Visibility="{x:Bind ViewModel.DetailTimeVisibility, Mode=OneWay}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="1" Text="Time Created:" FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="2" IsTextSelectionEnabled="True" Text="{x:Bind ViewModel.SelectedEvent.TimeCreatedDisplay, Mode=OneWay}" />
                                        <Button Grid.Column="0" Click="CopyDetailField_Click" Padding="4" Background="Transparent" BorderThickness="0"
                                                ToolTipService.ToolTip="Copy"
                                                Tag="{x:Bind ViewModel.SelectedEvent.TimeCreatedDisplay, Mode=OneWay}">
                                            <FontIcon Glyph="&#xE8C8;" FontSize="11" />
                                        </Button>
                                    </Grid>
                                    <Grid ColumnSpacing="6" Visibility="{x:Bind ViewModel.DetailProviderVisibility, Mode=OneWay}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="1" Text="Provider:" FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="2" IsTextSelectionEnabled="True" Text="{x:Bind ViewModel.SelectedEvent.ProviderName, Mode=OneWay}" TextWrapping="Wrap" />
                                        <Button Grid.Column="0" Click="CopyDetailField_Click" Padding="4" Background="Transparent" BorderThickness="0"
                                                ToolTipService.ToolTip="Copy"
                                                Tag="{x:Bind ViewModel.SelectedEvent.ProviderName, Mode=OneWay}">
                                            <FontIcon Glyph="&#xE8C8;" FontSize="11" />
                                        </Button>
                                    </Grid>
                                    <Grid ColumnSpacing="6" Visibility="{x:Bind ViewModel.DetailProviderGuidVisibility, Mode=OneWay}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="1" Text="Provider GUID:" FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="2" IsTextSelectionEnabled="True" Text="{x:Bind ViewModel.SelectedEvent.ProviderGuid, Mode=OneWay}" FontFamily="Consolas" />
                                        <Button Grid.Column="0" Click="CopyDetailField_Click" Padding="4" Background="Transparent" BorderThickness="0"
                                                ToolTipService.ToolTip="Copy"
                                                Tag="{x:Bind ViewModel.SelectedEvent.ProviderGuid, Mode=OneWay}">
                                            <FontIcon Glyph="&#xE8C8;" FontSize="11" />
                                        </Button>
                                    </Grid>
                                    <Grid ColumnSpacing="6" Visibility="{x:Bind ViewModel.DetailChannelVisibility, Mode=OneWay}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Click="CopyDetailField_Click" Padding="4" Background="Transparent" BorderThickness="0"
                                                ToolTipService.ToolTip="Copy"
                                                Tag="{x:Bind ViewModel.SelectedEvent.Channel, Mode=OneWay}">
                                            <FontIcon Glyph="&#xE8C8;" FontSize="11" />
                                        </Button>
                                        <TextBlock Grid.Column="1" Text="Channel:" FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="2" IsTextSelectionEnabled="True" Text="{x:Bind ViewModel.SelectedEvent.Channel, Mode=OneWay}" />
                                    </Grid>
                                    <Grid ColumnSpacing="6" Visibility="{x:Bind ViewModel.DetailTaskVisibility, Mode=OneWay}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="1" Text="Task:" FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="2" IsTextSelectionEnabled="True" Text="{x:Bind ViewModel.SelectedEvent.TaskName, Mode=OneWay}" />
                                        <Button Grid.Column="0" Click="CopyDetailField_Click" Padding="4" Background="Transparent" BorderThickness="0"
                                                ToolTipService.ToolTip="Copy"
                                                Tag="{x:Bind ViewModel.SelectedEvent.TaskName, Mode=OneWay}">
                                            <FontIcon Glyph="&#xE8C8;" FontSize="11" />
                                        </Button>
                                    </Grid>
                                    <Grid ColumnSpacing="6" Visibility="{x:Bind ViewModel.DetailKeywordsVisibility, Mode=OneWay}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="1" Text="Keywords:" FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="2" IsTextSelectionEnabled="True" Text="{x:Bind ViewModel.SelectedEvent.Keywords, Mode=OneWay}" />
                                        <Button Grid.Column="0" Click="CopyDetailField_Click" Padding="4" Background="Transparent" BorderThickness="0"
                                                ToolTipService.ToolTip="Copy"
                                                Tag="{x:Bind ViewModel.SelectedEvent.Keywords, Mode=OneWay}">
                                            <FontIcon Glyph="&#xE8C8;" FontSize="11" />
                                        </Button>
                                    </Grid>
                                    <Grid ColumnSpacing="6" Visibility="{x:Bind ViewModel.DetailUserVisibility, Mode=OneWay}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="1" Text="User:" FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="2" IsTextSelectionEnabled="True" Text="{x:Bind ViewModel.SelectedEvent.Username, Mode=OneWay}" />
                                        <Button Grid.Column="0" Click="CopyDetailField_Click" Padding="4" Background="Transparent" BorderThickness="0"
                                                ToolTipService.ToolTip="Copy"
                                                Tag="{x:Bind ViewModel.SelectedEvent.Username, Mode=OneWay}">
                                            <FontIcon Glyph="&#xE8C8;" FontSize="11" />
                                        </Button>
                                    </Grid>
                                    <Grid ColumnSpacing="6" Visibility="{x:Bind ViewModel.DetailProcessThreadVisibility, Mode=OneWay}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Click="CopyProcessThread_Click" Padding="4" Background="Transparent" BorderThickness="0"
                                                ToolTipService.ToolTip="Copy">
                                            <FontIcon Glyph="&#xE8C8;" FontSize="11" />
                                        </Button>
                                        <TextBlock Grid.Column="1" Text="Process / Thread:" FontWeight="SemiBold" />
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{x:Bind ViewModel.SelectedEvent.ProcessId, Mode=OneWay}" IsTextSelectionEnabled="True" />
                                            <TextBlock Text="/" />
                                            <TextBlock Text="{x:Bind ViewModel.SelectedEvent.ThreadId, Mode=OneWay}" IsTextSelectionEnabled="True" />
                                        </StackPanel>
                                    </Grid>
                                    <Grid ColumnSpacing="6" Visibility="{x:Bind ViewModel.DetailComputerVisibility, Mode=OneWay}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="1" Text="Computer:" FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="2" IsTextSelectionEnabled="True" Text="{x:Bind ViewModel.SelectedEvent.Computer, Mode=OneWay}" />
                                        <Button Grid.Column="0" Click="CopyDetailField_Click" Padding="4" Background="Transparent" BorderThickness="0"
                                                ToolTipService.ToolTip="Copy"
                                                Tag="{x:Bind ViewModel.SelectedEvent.Computer, Mode=OneWay}">
                                            <FontIcon Glyph="&#xE8C8;" FontSize="11" />
                                        </Button>
                                    </Grid>
                                    <StackPanel Spacing="6" Margin="0,4,0,0"
                                                Visibility="{x:Bind ViewModel.DetailMessageVisibility, Mode=OneWay}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <Button Click="CopyDetailField_Click" Padding="4" Background="Transparent" BorderThickness="0"
                                                    ToolTipService.ToolTip="Copy"
                                                    Tag="{x:Bind ViewModel.SelectedEvent.Message, Mode=OneWay}">
                                                <FontIcon Glyph="&#xE8C8;" FontSize="11" />
                                            </Button>
                                            <TextBlock Text="Message:" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        </StackPanel>
                                        <TextBlock Text="{x:Bind ViewModel.SelectedEvent.Message, Mode=OneWay}" TextWrapping="Wrap" IsTextSelectionEnabled="True" />
                                    </StackPanel>
                                    <Expander Header="XML View" HorizontalAlignment="Stretch" Margin="0,8,0,0"
                                              Visibility="{x:Bind ViewModel.DetailXmlVisibility, Mode=OneWay}">
                                        <TextBox Text="{x:Bind ViewModel.SelectedEvent.Xml, Mode=OneWay}"
                                                 IsReadOnly="True"
                                                 TextWrapping="Wrap"
                                                 AcceptsReturn="True"
                                                 FontFamily="Consolas"
                                                 Height="200" />
                                    </Expander>
                                </StackPanel>
                            </Grid>

                            <!-- Placeholder when no event is selected -->
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Spacing="8" Margin="0,40,0,0"
                                        Visibility="{x:Bind ViewModel.SelectedEvent, Mode=OneWay, Converter={StaticResource NullToVisibleConverter}}">
                                <FontIcon Glyph="&#xE946;" FontSize="32" Opacity="0.4" />
                                <TextBlock Text="Click an event above to see its details"
                                           Opacity="0.6" HorizontalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                    </Grid>
                </Border>

                <!-- Collapsed details bar (only visible when collapsed) -->
                <Border x:Name="CollapsedDetailsBar" Grid.Row="2" Visibility="Collapsed"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="12,8" Margin="0,2,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Event Details" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Click="ExpandDetails_Click" Padding="6"
                                ToolTipService.ToolTip="Show details"
                                Background="Transparent" BorderThickness="0">
                            <FontIcon Glyph="&#xE70E;" FontSize="12" />
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- Bottom: Status bar -->
        <Border Grid.Row="2" Padding="12,6" Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="4">
            <StackPanel Orientation="Horizontal" Spacing="16">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE7C3;" FontSize="12" Opacity="0.7" />
                    <TextBlock Text="{x:Bind ViewModel.CurrentSource, Mode=OneWay}" FontWeight="SemiBold" />
                </StackPanel>
                <TextBlock Text="•" Opacity="0.5" />
                <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" />
                <TextBlock Text="•" Opacity="0.5" />
                <TextBlock>
                    <Run Text="Showing" />
                    <Run Text="{x:Bind ViewModel.FilteredEvents.Count, Mode=OneWay}" />
                    <Run Text="events" />
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Page>
